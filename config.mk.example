# Copy this file to config.mk and fill in your values.

PROJECT_ID=your-gcp-project-id
ZONE=europe-west2-b
BUCKET=gs://my-gpu-workspace-bucket
VM_NAME=gpu-workspace
SNAPSHOT=gpu-golden-image
VM_USER=your-linux-username

# SYNC_DIRS — space-separated list of "local_path:gcs_subpath" pairs.
SYNC_DIRS =

# SSH_FORWARDS — space-separated list of port forwardings.
SSH_FORWARDS = 7860:7860

# Hardware (Optional - Defaults to n1-standard-4 + T4)
MACHINE_TYPE        = n1-standard-4
ACCELERATOR         = count=1,type=nvidia-tesla-t4
DOWNLOADER_MACHINE_TYPE = e2-small
